# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_NAME=powerup-api
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ─────────────────────────────────────────────────────────────
# Security / JWT
# ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─────────────────────────────────────────────────────────────
# Database
# asyncpg driver  → used by SQLAlchemy async engine at runtime
# psycopg2 driver → used by Alembic env.py (sync, migrations only)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/powerup_db
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/powerup_db

# Connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ─────────────────────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ─────────────────────────────────────────────────────────────
# CORS
# Comma-separated list of allowed origins
# React Native (Expo) and React admin dashboard
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ─────────────────────────────────────────────────────────────
# API
# ─────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
DOCS_ENABLED=true            # Set to false in production
